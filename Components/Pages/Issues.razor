@page "/issues"
@rendermode InteractiveServer
@inject TodoApp.Services.GhService Gh

<h2>GitHub Issues — eltjo/TodoApp</h2>

<!-- Nieuw issue formulier -->
<details style="margin-bottom:20px; border:1px solid #d0d7de; border-radius:8px; padding:16px;">
    <summary style="cursor:pointer; font-weight:600; font-size:1rem;">＋ Nieuw issue aanmaken</summary>
    <div style="margin-top:14px; display:flex; flex-direction:column; gap:10px; max-width:600px;">
        <input @bind="NewTitle"
               placeholder="Titel"
               style="padding:8px 10px; border:1px solid #d0d7de; border-radius:6px; font-size:0.95rem;" />
        <textarea @bind="NewBody"
                  placeholder="Beschrijving (optioneel)"
                  rows="4"
                  style="padding:8px 10px; border:1px solid #d0d7de; border-radius:6px; font-size:0.95rem; resize:vertical;" />
        @if (CreateError is not null)
        {
            <p style="color:red; margin:0;">⚠️ @CreateError</p>
        }
        @if (CreateSuccess is not null)
        {
            <p style="color:green; margin:0;">✓ Issue aangemaakt: <a href="@CreateSuccess" target="_blank">@CreateSuccess</a></p>
        }
        <div>
            <button @onclick="CreateIssue" disabled="@(Creating || string.IsNullOrWhiteSpace(NewTitle))"
                    style="padding:7px 18px; background:#2da44e; color:white; border:none; border-radius:6px; cursor:pointer; font-size:0.95rem;">
                @(Creating ? "Aanmaken..." : "Issue aanmaken")
            </button>
        </div>
    </div>
</details>

<!-- Filter & vernieuwen -->
<div style="display:flex; gap:12px; margin-bottom:16px; align-items:center;">
    <select @bind="SelectedState" style="padding:6px 10px; border-radius:6px;">
        <option value="open">Open</option>
        <option value="closed">Closed</option>
        <option value="all">Alle</option>
    </select>
    <button @onclick="LoadIssues" disabled="@Loading" style="padding:6px 14px; border-radius:6px; cursor:pointer;">
        @(Loading ? "Laden..." : "↻ Vernieuwen")
    </button>
</div>

@if (ErrorMessage is not null)
{
    <p style="color:red;">⚠️ @ErrorMessage</p>
}
else if (IssueList is null)
{
    <p>Laden...</p>
}
else if (!IssueList.Any())
{
    <p>Geen issues gevonden.</p>
}
else
{
    <table style="width:100%; border-collapse:collapse;">
        <thead>
            <tr style="border-bottom:2px solid #ccc; text-align:left;">
                <th style="padding:8px 12px;">#</th>
                <th style="padding:8px 12px;">Titel</th>
                <th style="padding:8px 12px;">Status</th>
                <th style="padding:8px 12px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var issue in IssueList)
            {
                <tr style="border-bottom:1px solid #eee;">
                    <td style="padding:8px 12px; color:gray;">@issue.Number</td>
                    <td style="padding:8px 12px; font-weight:500;">@issue.Title</td>
                    <td style="padding:8px 12px;">
                        <span style="background:@(issue.State == "OPEN" ? "#2da44e" : "#8250df"); color:white; padding:2px 10px; border-radius:12px; font-size:0.8rem;">
                            @issue.State.ToLower()
                        </span>
                    </td>
                    <td style="padding:8px 12px;">
                        <a href="@issue.Url" target="_blank" style="color:#0969da; text-decoration:none;">Bekijk →</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<TodoApp.Models.GitHubIssue>? IssueList;
    private string SelectedState = "open";
    private bool Loading = false;
    private string? ErrorMessage;

    private string NewTitle = string.Empty;
    private string NewBody = string.Empty;
    private bool Creating = false;
    private string? CreateError;
    private string? CreateSuccess;

    protected override async Task OnInitializedAsync()
        => await LoadIssues();

    private async Task LoadIssues()
    {
        Loading = true;
        ErrorMessage = null;
        IssueList = null;
        try
        {
            IssueList = await Gh.GetIssuesAsync(SelectedState);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task CreateIssue()
    {
        Creating = true;
        CreateError = null;
        CreateSuccess = null;
        try
        {
            var url = await Gh.CreateIssueAsync(NewTitle, NewBody);
            CreateSuccess = url;
            NewTitle = string.Empty;
            NewBody = string.Empty;
            await LoadIssues();
        }
        catch (Exception ex)
        {
            CreateError = ex.Message;
        }
        finally
        {
            Creating = false;
        }
    }
}
